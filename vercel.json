{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "telemetry-frontend/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/main.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/telemetry-frontend/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/telemetry-frontend/dist/index.html"
    }
  ]
}